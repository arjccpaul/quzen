{
  "name": "quzen",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace=apps/web",
    "dev:api": "npm run start:dev --workspace=apps/api",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "db:migrate": "npm run migrate --workspace=packages/prisma",
    "db:generate": "npm run generate --workspace=packages/prisma",
    "db:studio": "npm run studio --workspace=packages/prisma"
  }
}
